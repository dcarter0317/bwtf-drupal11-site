.git

# Ignore Windows zone identifier metadata files.
*:Zone.Identifier

# Composer dependencies are managed outside the repo.
/vendor/

# DDEV configuration should not be committed.
/.ddev/

# DDEV backups should not be committed.
/.ddev/backups/

# Drupal runtime files.
/web/sites/default/files/
/web/.htaccess
.DS_Store
.DS_Store

# Composer
/vendor/

# Node
/node_modules/

# Drupal uploaded files
/web/sites/default/files/

# Private files (if your site uses one)
/private/

# Local settings (do NOT commit these)
/web/sites/default/settings.php
/web/sites/default/services.yml

# Database dumps
*.sql
*.sql.gz

# Archives
*.tar
*.tar.gz
*.zip

# macOS
.DS_Store

# VS Code
.vscode/

# Remote VS Code server (shouldn't be in your repo anyway)
.vscode-server/

# Local/editor files
.idea/
*.log

# Drupal generated files
/web/sites/default/files/
/web/sites/*/files/

# Composer-managed Drupal files
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/

# Runtime/user files
/web/sites/default/files/
/web/sites/*/files/

# Local/private files
/web/sites/default/settings.php
/web/sites/default/services.yml
.env
.env.*
.idea/
*.log

# Backups/archives/database dumps
/backups/
/backup/
*.sql
*.sql.gz
*.tar
*.tar.gz
*.zip
*.bak
*.old