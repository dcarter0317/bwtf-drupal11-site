.git

# OS-specific files
.DS_Store
*:Zone.Identifier

# IDEs and Editors
.idea/
.vscode/
.vscode-server/
*.log

# Composer & Node dependencies
/vendor/
/node_modules/

# DDEV configuration & backups
/.ddev/
/.ddev/backups/

# Local Environment files
.env
.env.*

# Drupal Core and Contributed projects (managed by Composer)
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/

# Drupal runtime & site-specific files
/web/.htaccess
/web/sites/default/files/
/web/sites/*/files/
/private/

# Local settings (do NOT commit these)
/web/sites/default/settings.php
/web/sites/default/services.yml

# Backups, archives, and database dumps
/backups/
/backup/
*.sql
*.sql.gz
*.tar
*.tar.gz
*.zip
*.bak
*.old